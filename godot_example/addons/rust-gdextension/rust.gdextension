[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.3
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://../rust/target/debug/librust_gdextension.so"
linux.release.x86_64 =   "res://../rust/target/release/librust_gdextension.so"
windows.debug.x86_64 =   "res://../rust/target/release/rust_gdextension.dll"
windows.release.x86_64 = "res://../rust/target/release/rust_gdextension.dll"
macos.debug =            "res://../rust/target/debug/librust_gdextension.dylib"
macos.release =          "res://../rust/target/release/librust_gdextension.dylib"
macos.debug.arm64 =      "res://../rust/target/debug/librust_gdextension.dylib"
macos.release.arm64 =    "res://../rust/target/release/librust_gdextension.dylib"
android.debug.arm64 =    "res://../rust/target/debug/librust_gdextension.so"
android.release.arm64 =  "res://../rust/target/release/librust_gdextension.so"
android.debug.x86_64 =   "res://../rust/target/debug/librust_gdextension.so"
android.release.x86_64 = "res://../rust/target/release/librust_gdextension.so"
